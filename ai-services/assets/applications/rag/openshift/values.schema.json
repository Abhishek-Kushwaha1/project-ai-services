{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Application Values Schema",
  "type": "object",
  "properties": {
    "opensearch": {
      "type": "object",
      "properties": {
        "memoryLimit": {
          "type": "string",
          "pattern": "^[0-9]+(Ki|Mi|Gi)$",
          "description": "Memory limit for OpenSearch."
        },
        "storage": {
          "type": "string",
          "pattern": "^[0-9]+(Ki|Mi|Gi)$",
          "description": "Storage size for OpenSearch."
        }
      },
      "required": ["memoryLimit", "storage"]
    }
  },
  "required": ["opensearch"]
}